# ── Server ────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3003
SESSION_SECRET=<generate-a-random-64-char-string>

# ── Database ──────────────────────────────────────────────────────────
# DB_PATH=./data/logistics.db   # optional override; defaults to src/db/logistics.db

# ── AWS S3 (file uploads) ─────────────────────────────────────────────
# Leave blank to use local disk storage (dev/demo mode)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
S3_BUCKET=zain-logistics-uploads

# ── Shipping carrier APIs ─────────────────────────────────────────────
# Leave blank to use demo/manual data
MAERSK_CONSUMER_KEY=
HAPAG_LLOYD_API_KEY=
CMA_CGM_API_KEY=
